		{"id":"b1_checklist","type":"text","text":"- [ ] Отмена визита в ленте\n- [ ] Push-уведомления\n- [ ] Экспорт отчётов (PDF/Excel)\n- [ ] Онлайн-оплата интеграция\n- [ ] СМС авторизация\n","borderColor":"#334155","x":-2088,"y":-1716,"width":456,"height":176,"color":"#020617"},
