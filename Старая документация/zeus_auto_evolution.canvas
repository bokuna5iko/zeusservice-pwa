		{"id":"b2_check_box","type":"text","text":"","borderColor":"#f59e0b","x":-1350,"y":-838,"width":480,"height":140,"color":"#0f172a"},
		{"id":"b2_rec_content","type":"text","text":"🎯 Блок 1: Шины / Диски\n  └─ Партнёр: шиномонтаж\n\n🎯 Блок 2: Запчасти / Аксессуары  \n  └─ Партнёр: автомагазин\n\n🎯 Блок 3: Страховка / ОСАГО\n  └─ Партнёр: страховая\n\n🎯 Блок 4: Аренда авто\n  └─ Партнёр: прокат\n\n🎯 Блок 5: Такси / Каршеринг\n  └─ Партнёр: агрегатор\n\n🎯 Блок 6: Автошкола\n  └─ Партнёр: автошкола\n\n(прокрутка ← →, 3 видимых)","borderColor":"#334155","x":-1340,"y":-1088,"width":460,"height":215,"color":"#020617"},
		{"id":"b2_check_title","type":"text","text":"📋 Чеклист: добавляем рекламу","borderColor":"#f59e0b","x":-1338,"y":-826,"width":456,"height":28,"color":"rgba(245,158,11,0.08)"},
		{"id":"b2_checklist","type":"text","text":"☐ API для рекламных блоков\n☐ Система кликов / просмотров\n☐ Договоры с 3-5 партнёрами\n☐ A/B тестирование позиций","borderColor":"#334155","x":-1338,"y":-790,"width":456,"height":80,"color":"#020617"},
