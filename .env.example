# ============================================================
# ЛОКАЛЬНАЯ РАЗРАБОТКА БЕЗ DOCKER
# ============================================================
# 1. Скопируйте backend/.env.example → backend/.env
# 2. Замените ВАШ_ПАРОЛЬ на пароль PostgreSQL
# 3. PostgreSQL должен быть запущен локально (brew services start postgresql@15)
#
# Frontend проксирует /api → localhost:3000 (vite.config.js)
# Отдельный .env для frontend не обязателен.

# --- Ниже переменные для docker-compose (на сервере) ---

DB_PASSWORD=your_db_password
JWT_SECRET=your_jwt_secret
REFRESH_SECRET=your_refresh_secret
HOST_IP=127.0.0.1
SERVER_NAME=localhost

# SMS-авторизация
# dev     — код пишется в лог backend (для разработки)
# smsaero — SMS Aero (SMS_AERO_EMAIL + SMS_AERO_API_KEY)
# smsru   — SMS.ru (нужен SMS_API_KEY)
# smsc    — SMSC.ru (нужны SMS_LOGIN и SMS_PASSWORD)
SMS_PROVIDER=smsaero
SMS_CODE_TTL_MINUTES=5
SMS_RESEND_COOLDOWN_SEC=60

# SMS Aero
# SMS_AERO_EMAIL=
# SMS_AERO_API_KEY=
# SMS_AERO_SIGN=SMS Aero

PD_CONSENT_VERSION=1.3
