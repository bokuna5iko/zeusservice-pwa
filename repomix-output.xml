    right: 20px;
    font-size: 32px;
    color: #333;
    cursor: pointer;
    line-height: 1;
    z-index: 10; /* Чтобы точно была сверху */
}

.modal-content {
    background-color: white;
    padding: 30px;
    border-radius: 30px;
