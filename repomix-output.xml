}

/* Модальное окно */
.modal {
    display: none; 
    position: fixed;
    z-index: 9999; /* Выше всех, даже выше шапки */
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.85); /* Затемнение */
    backdrop-filter: blur(8px);
    align-items: center; /* Центрируем по вертикали */
