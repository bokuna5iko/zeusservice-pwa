# Backend — скопируйте в backend/.env

PORT=3000

# PostgreSQL (локально без Docker)
DATABASE_URL=postgres://zeus_user:ВАШ_ПАРОЛЬ@localhost:5432/zeus_auto_db

# Секреты для JWT (любые длинные случайные строки, минимум 32 символа)
JWT_SECRET=dev_jwt_secret_change_me_32chars_min
REFRESH_SECRET=dev_refresh_secret_change_me_32chars

# SMS (dev = код в логе сервера, без реальных SMS)
SMS_PROVIDER=dev
SMS_CODE_TTL_MINUTES=5
SMS_RESEND_COOLDOWN_SEC=60

# Версия текста согласия на обработку ПДн (152-ФЗ)
PD_CONSENT_VERSION=1.0
