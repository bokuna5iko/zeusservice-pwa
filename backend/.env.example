# Backend — скопируйте в backend/.env

PORT=3000

# PostgreSQL (локально без Docker)
DATABASE_URL=postgres://zeus_user:ВАШ_ПАРОЛЬ@localhost:5432/zeus_auto_db

# Секреты для JWT (любые длинные случайные строки, минимум 32 символа)
JWT_SECRET=dev_jwt_secret_change_me_32chars_min
REFRESH_SECRET=dev_refresh_secret_change_me_32chars

# ============================================================
# SMS
# ============================================================
# dev     — код в логе сервера (локальная разработка)
# smsaero — SMS Aero (рекомендуется)
# smsru   — SMS.ru
# smsc    — SMSC.ru
SMS_PROVIDER=smsaero

SMS_CODE_TTL_MINUTES=5
SMS_RESEND_COOLDOWN_SEC=60

# --- SMS Aero (https://smsaero.ru → Настройки → API-ключ) ---
# Логин = email, с которым регистрировались в SMS Aero
SMS_AERO_EMAIL=your@email.com
SMS_AERO_API_KEY=ВСТАВЬТЕ_API_КЛЮЧ_СЮДА
# Имя отправителя: для теста "SMS Aero", потом своё (Zeus Auto)
SMS_AERO_SIGN=SMS Aero

# --- SMS.ru (если понадобится) ---
# SMS_API_KEY=
# SMS_SENDER=Zeus Auto

# --- SMSC.ru (если понадобится) ---
# SMS_LOGIN=
# SMS_PASSWORD=

# Версия текста согласия на обработку ПДн (152-ФЗ)
PD_CONSENT_VERSION=1.3
