# backend/Dockerfile

# 1. Базовый образ. Alpine — легковесный Linux (~180MB вместо ~1GB)
FROM node:20-alpine

# 2. Рабочая директория внутри контейнера. Все следующие команды выполняются здесь
WORKDIR /app

# 3. Копируем ТОЛЬКО файлы зависимостей. Это позволяет кэшировать слой npm install
COPY package*.json ./
RUN npm ci --only=production

# 4. Устанавливаем зависимости. Слой кэшируется, если package.json не менялся
#RUN npm install

# 5. Копируем остальной код. Этот слой будет пересобираться при каждом изменении кода
COPY . .

# 6. Открываем порт 3000 (информационно, не пробрасывает автоматически)
EXPOSE 3000

# 7. Команда запуска. Для разработки используем nodemon (hot reload)
CMD ["node", "server.js"]
